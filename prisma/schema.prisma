generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  password           String
  role               String   @default("ENGINEER")
  shopId             String?
  isSuperAdmin       Boolean  @default(false)
  commissionRate     Float    @default(0)
  emailVerified      Boolean  @default(false)
  emailVerifyToken   String?
  resetPasswordToken String?

  shop             Shop?             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdOrders    WorkOrder[]       @relation("CreatedBy")
  assignedOrders   WorkOrder[]       @relation("AssignedTo")
  logs             OperationLog[]
  notifications    Notification[]
  notes            InternalNote[]
  stockAdjustments StockAdjustment[]
  shifts           Shift[]
  payments         Payment[]
  expenses         Expense[]
  customerNotes    CustomerNote[]
  purchaseOrders   PurchaseOrder[]
  commissions      EngineerCommission[]
  enrollments      Enrollment[]
  lessonProgress   LessonProgress[]
  certificates     AcademyCertificate[]

  @@index([shopId])
}

model Shop {
  id                 String   @id @default(cuid())
  name               String
  address            String?
  phone              String?
  email              String?
  logoUrl            String?
  googleMapsUrl      String?
  status             String   @default("TRIAL")
  plan               String   @default("FREE")
  trialEndsAt        DateTime?
  onboardingComplete Boolean  @default(false)
  currency           String   @default("MAD")
  taxEnabled         Boolean  @default(false)
  taxRate            Float    @default(0)
  taxLabel           String   @default("TVA")
  city               String?
  country            String?
  lat                Float?
  lng                Float?
  certification      String?
  createdAt          DateTime @default(now())

  users          User[]
  workOrders     WorkOrder[]
  spareParts     SparePart[]
  shifts         Shift[]
  expenses       Expense[]
  customerNotes  CustomerNote[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  appointments   Appointment[]
  availability   ShopAvailability[]
  closures       ShopClosure[]
  shopSettings   ShopSettings?
  commissions    EngineerCommission[]
  apiKeys        ApiKey[]
  shopCert       Certification?
}

model Certification {
  id        String    @id @default(cuid())
  shopId    String    @unique
  level     String
  earnedAt  DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model WorkOrder {
  id          String @id @default(cuid())
  orderNumber String @unique @default(cuid())

  deviceBrand     String
  deviceModel     String
  serialNumber    String?
  imei            String?
  warrantyStart   DateTime?
  warrantyEnd     DateTime?
  isUnderWarranty Boolean @default(false)

  customerName  String
  customerPhone String
  customerEmail String?

  faultDescription String
  appearance       String?
  remarks          String?

  serviceType String @default("IN_STORE")
  repairType  String?
  faultLevel  String @default("LOW")

  status      String @default("RECEIVED")

  receivedAt  DateTime  @default(now())
  doneAt      DateTime?
  deliveredAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  bounceCount Int     @default(0)
  isBounce    Boolean @default(false)

  subtotal         Float  @default(0)
  quotationItems   Float  @default(0)
  discount         Float  @default(0)
  total            Float  @default(0)
  collected        Float  @default(0)
  quotationRemarks String?
  taxRate          Float  @default(0)

  lastReminderAt DateTime?
  slaDeadline    DateTime?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopId     String
  userId     String
  assignedTo String?

  shop          Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  creator       User                  @relation("CreatedBy", fields: [userId], references: [id])
  assignee      User?                 @relation("AssignedTo", fields: [assignedTo], references: [id])
  parts         WorkOrderPart[]
  lineItems     QuotationLineItem[]
  logs          OperationLog[]
  attachments   WorkOrderAttachment[]
  bounces       BounceRepair[]
  notifications Notification[]
  notes         InternalNote[]
  rating        SatisfactionRating?
  smsLogs       SmsNotification[]
  payments      Payment[]
  checklist     DiagnosisCheck[]
  messages      CustomerMessage[]

  @@index([shopId])
  @@index([customerPhone])
  @@index([status])
}

model CustomerMessage {
  id         String   @id @default(cuid())
  message    String
  senderType String   // "SHOP" or "CUSTOMER"
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model QuotationLineItem {
  id     String @id @default(cuid())
  label  String
  amount Float

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model BounceRepair {
  id        String   @id @default(cuid())
  reason    String
  scenario  String
  createdAt DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model Notification {
  id      String  @id @default(cuid())
  type    String
  message String
  read    Boolean @default(false)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model SparePart {
  id          String  @id @default(cuid())
  name        String
  partNumber  String?
  description String?
  unitPrice   Float   @default(0)
  stock       Int     @default(0)

  shopId      String
  shop        Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  usages             WorkOrderPart[]
  adjustments        StockAdjustment[]
  purchaseOrderItems PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

model WorkOrderPart {
  id        String @id @default(cuid())
  quantity  Int    @default(1)
  unitPrice Float
  total     Float

  workOrderId String
  sparePartId String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  sparePart SparePart @relation(fields: [sparePartId], references: [id])

  createdAt DateTime @default(now())
}

model OperationLog {
  id          String  @id @default(cuid())
  action      String
  description String?

  createdAt DateTime @default(now())

  workOrderId String
  userId      String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model WorkOrderAttachment {
  id       String @id @default(cuid())
  filename String
  path     String
  tag      String @default("other")

  createdAt DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model InternalNote {
  id      String @id @default(cuid())
  message String

  createdAt DateTime @default(now())

  workOrderId String
  userId      String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
}

model StockAdjustment {
  id       String  @id @default(cuid())
  quantity Int
  type     String
  reason   String?

  createdAt DateTime @default(now())

  sparePartId String
  userId      String

  sparePart SparePart @relation(fields: [sparePartId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model SatisfactionRating {
  id          String  @id @default(cuid())
  workOrderId String  @unique
  rating      Int
  comment     String?

  createdAt DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model SmsNotification {
  id          String    @id @default(cuid())
  workOrderId String
  phone       String
  message     String
  status      String    @default("pending")
  provider    String    @default("mock")
  sentAt      DateTime?

  createdAt DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model Shift {
  id        String    @id @default(cuid())
  startTime DateTime
  endTime   DateTime?
  notes     String?

  userId String
  shopId String?

  user User  @relation(fields: [userId], references: [id])
  shop Shop? @relation(fields: [shopId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  workOrderId String
  amount      Float
  method      String   @default("CASH")
  note        String?
  collectedBy String
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  collector User      @relation(fields: [collectedBy], references: [id])
}

model WorkOrderTemplate {
  id                String   @id @default(cuid())
  name              String
  category          String   @default("")
  deviceBrand       String   @default("")
  deviceModel       String   @default("")
  faultDescription  String
  repairType        String   @default("")
  faultLevel        String   @default("LOW")
  serviceType       String   @default("IN_STORE")
  defaultPrice      Float    @default(0)
  estimatedDuration Int      @default(0)
  slaHours          Int      @default(24)
  defaultParts      Json     @default("[]")
  defaultLineItems  Json     @default("[]")
  shopId            String
  createdAt         DateTime @default(now())
}

model DiagnosisCheck {
  id          String   @id @default(cuid())
  workOrderId String
  item        String
  status      String   @default("PENDING")
  note        String?
  checkedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}
model CustomerNote {
  id        String   @id @default(cuid())
  phone     String
  shopId    String
  userId    String
  message   String
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([phone, shopId])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String   @default("OTHER")
  note        String?
  date        DateTime @default(now())
  shopId      String
  userId      String
  createdAt   DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Appointment {
  id               String   @id @default(cuid())
  shopId           String
  customerName     String
  customerPhone    String
  deviceBrand      String
  deviceModel      String
  faultDescription String
  scheduledAt      DateTime
  duration         Int      @default(60)
  status           String   @default("PENDING")
  notes            String?
  createdAt        DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
}

model ShopAvailability {
  id                  String   @id @default(cuid())
  shopId              String
  dayOfWeek           Int
  openTime            String   @default("09:00")
  closeTime           String   @default("18:00")
  isOpen              Boolean  @default(true)
  slotDurationMinutes Int      @default(60)
  maxConcurrent       Int      @default(2)
  createdAt           DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, dayOfWeek])
}

model ShopClosure {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  shopId    String
  createdAt DateTime @default(now())

  shop           Shop            @relation(fields: [shopId], references: [id])
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  orderNumber String?  @unique
  supplierId  String
  shopId      String
  userId      String
  status      String   @default("DRAFT")
  notes       String?
  totalAmount Float    @default(0)
  createdAt   DateTime @default(now())

  supplier Supplier           @relation(fields: [supplierId], references: [id])
  shop     Shop               @relation(fields: [shopId], references: [id])
  creator  User               @relation(fields: [userId], references: [id])
  items    PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  sparePartId     String
  quantity        Int
  unitCost        Float
  totalCost       Float
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sparePart     SparePart     @relation(fields: [sparePartId], references: [id])
}

model ShopSettings {
  id              String   @id @default(cuid())
  shopId          String   @unique
  defaultSlaHours Int      @default(24)

  // Customer SMS/WhatsApp notifications
  smsEnabled      Boolean  @default(false)
  smsProvider     String   @default("mock")
  notifyStatuses  String   @default("DONE,DELIVERED")
  smsLanguage     String   @default("en")
  includeTrackingLink Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
}

model EngineerCommission {
  id               String   @id @default(cuid())
  userId           String
  shopId           String
  month            String
  totalOrders      Int      @default(0)
  totalRevenue     Float    @default(0)
  commissionRate   Float    @default(0)
  commissionAmount Float    @default(0)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([userId, shopId, month])
}
model ApiKey {
  id        String    @id @default(cuid())
  key       String    @unique
  name      String
  shopId    String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  isActive  Boolean   @default(true)

  shop Shop @relation(fields: [shopId], references: [id])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  thumbnail   String?
  duration    Int      @default(0)
  level       String   @default("BEGINNER")
  category    String   @default("General")
  instructor  String   @default("FixFlow Team")
  free        Boolean  @default(true)
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())

  lessons      Lesson[]
  enrollments  Enrollment[]
  certificates AcademyCertificate[]
}

model Lesson {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  content   String   @db.Text
  videoUrl  String?
  duration  Int      @default(10)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model AcademyCertificate {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  issuedAt        DateTime @default(now())
  certificateCode String   @unique

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}
