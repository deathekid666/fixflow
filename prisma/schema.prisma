generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String
  password           String
  role               String   @default("ENGINEER")
  shopId             String?
  isSuperAdmin       Boolean  @default(false)
  emailVerified      Boolean  @default(false)
  emailVerifyToken   String?
  resetPasswordToken String?

  shop             Shop?             @relation(fields: [shopId], references: [id])
  createdOrders    WorkOrder[]       @relation("CreatedBy")
  assignedOrders   WorkOrder[]       @relation("AssignedTo")
  logs             OperationLog[]
  notifications    Notification[]
  notes            InternalNote[]
  stockAdjustments StockAdjustment[]
  shifts           Shift[]
  payments         Payment[]
  expenses         Expense[]
  customerNotes    CustomerNote[]
  purchaseOrders   PurchaseOrder[]
}

model Shop {
  id                 String   @id @default(cuid())
  name               String
  address            String?
  phone              String?
  email              String?
  logoUrl            String?
  status             String   @default("TRIAL")
  plan               String   @default("FREE")
  trialEndsAt        DateTime?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())

  users          User[]
  workOrders     WorkOrder[]
  spareParts     SparePart[]
  shifts         Shift[]
  expenses       Expense[]
  customerNotes  CustomerNote[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  appointments   Appointment[]
}

model WorkOrder {
  id          String @id @default(cuid())
  orderNumber String @unique @default(cuid())

  deviceBrand     String
  deviceModel     String
  serialNumber    String?
  imei            String?
  warrantyStart   DateTime?
  warrantyEnd     DateTime?
  isUnderWarranty Boolean @default(false)

  customerName  String
  customerPhone String
  customerEmail String?

  faultDescription String
  appearance       String?
  remarks          String?

  serviceType String @default("IN_STORE")
  repairType  String?
  faultLevel  String @default("LOW")

  status      String @default("RECEIVED")

  receivedAt  DateTime  @default(now())
  doneAt      DateTime?
  deliveredAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  bounceCount Int     @default(0)
  isBounce    Boolean @default(false)

  subtotal         Float  @default(0)
  quotationItems   Float  @default(0)
  discount         Float  @default(0)
  total            Float  @default(0)
  collected        Float  @default(0)
  quotationRemarks String?

  lastReminderAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopId     String
  userId     String
  assignedTo String?

  shop          Shop                  @relation(fields: [shopId], references: [id])
  creator       User                  @relation("CreatedBy", fields: [userId], references: [id])
  assignee      User?                 @relation("AssignedTo", fields: [assignedTo], references: [id])
  parts         WorkOrderPart[]
  lineItems     QuotationLineItem[]
  logs          OperationLog[]
  attachments   WorkOrderAttachment[]
  bounces       BounceRepair[]
  notifications Notification[]
  notes         InternalNote[]
  rating        SatisfactionRating?
  smsLogs       SmsNotification[]
  payments      Payment[]
  checklist     DiagnosisCheck[]
  messages      CustomerMessage[]
}

model CustomerMessage {
  id         String   @id @default(cuid())
  message    String
  senderType String   // "SHOP" or "CUSTOMER"
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
}

model QuotationLineItem {
  id     String @id @default(cuid())
  label  String
  amount Float

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  createdAt DateTime @default(now())
}

model BounceRepair {
  id        String   @id @default(cuid())
  reason    String
  scenario  String
  createdAt DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
}

model Notification {
  id      String  @id @default(cuid())
  type    String
  message String
  read    Boolean @default(false)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model SparePart {
  id          String  @id @default(cuid())
  name        String
  partNumber  String?
  description String?
  unitPrice   Float   @default(0)
  stock       Int     @default(0)

  shopId      String
  shop        Shop              @relation(fields: [shopId], references: [id])
  usages             WorkOrderPart[]
  adjustments        StockAdjustment[]
  purchaseOrderItems PurchaseOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkOrderPart {
  id        String @id @default(cuid())
  quantity  Int    @default(1)
  unitPrice Float
  total     Float

  workOrderId String
  sparePartId String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  sparePart SparePart @relation(fields: [sparePartId], references: [id])

  createdAt DateTime @default(now())
}

model OperationLog {
  id          String  @id @default(cuid())
  action      String
  description String?

  createdAt DateTime @default(now())

  workOrderId String
  userId      String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model WorkOrderAttachment {
  id       String @id @default(cuid())
  filename String
  path     String
  tag      String @default("other")

  createdAt DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
}

model InternalNote {
  id      String @id @default(cuid())
  message String

  createdAt DateTime @default(now())

  workOrderId String
  userId      String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model StockAdjustment {
  id       String  @id @default(cuid())
  quantity Int
  type     String
  reason   String?

  createdAt DateTime @default(now())

  sparePartId String
  userId      String

  sparePart SparePart @relation(fields: [sparePartId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model SatisfactionRating {
  id          String  @id @default(cuid())
  workOrderId String  @unique
  rating      Int
  comment     String?

  createdAt DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
}

model SmsNotification {
  id          String    @id @default(cuid())
  workOrderId String
  phone       String
  message     String
  status      String    @default("pending")
  provider    String    @default("mock")
  sentAt      DateTime?

  createdAt DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
}

model Shift {
  id        String    @id @default(cuid())
  startTime DateTime
  endTime   DateTime?
  notes     String?

  userId String
  shopId String?

  user User  @relation(fields: [userId], references: [id])
  shop Shop? @relation(fields: [shopId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  workOrderId String
  amount      Float
  method      String   @default("CASH")
  note        String?
  collectedBy String
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  collector User      @relation(fields: [collectedBy], references: [id])
}

model WorkOrderTemplate {
  id                String   @id @default(cuid())
  name              String
  category          String   @default("")
  deviceBrand       String   @default("")
  deviceModel       String   @default("")
  faultDescription  String
  repairType        String   @default("")
  faultLevel        String   @default("LOW")
  serviceType       String   @default("IN_STORE")
  defaultPrice      Float    @default(0)
  estimatedDuration Int      @default(0)
  defaultParts      Json     @default("[]")
  defaultLineItems  Json     @default("[]")
  shopId            String
  createdAt         DateTime @default(now())
}

model DiagnosisCheck {
  id          String   @id @default(cuid())
  workOrderId String
  item        String
  status      String   @default("PENDING")
  note        String?
  checkedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}
model CustomerNote {
  id        String   @id @default(cuid())
  phone     String
  shopId    String
  userId    String
  message   String
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([phone, shopId])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String   @default("OTHER")
  note        String?
  date        DateTime @default(now())
  shopId      String
  userId      String
  createdAt   DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Appointment {
  id               String   @id @default(cuid())
  shopId           String
  customerName     String
  customerPhone    String
  deviceBrand      String
  deviceModel      String
  faultDescription String
  scheduledAt      DateTime
  duration         Int      @default(60)
  status           String   @default("PENDING")
  notes            String?
  createdAt        DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  shopId    String
  createdAt DateTime @default(now())

  shop           Shop            @relation(fields: [shopId], references: [id])
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  orderNumber String?  @unique
  supplierId  String
  shopId      String
  userId      String
  status      String   @default("DRAFT")
  notes       String?
  totalAmount Float    @default(0)
  createdAt   DateTime @default(now())

  supplier Supplier           @relation(fields: [supplierId], references: [id])
  shop     Shop               @relation(fields: [shopId], references: [id])
  creator  User               @relation(fields: [userId], references: [id])
  items    PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  sparePartId     String
  quantity        Int
  unitCost        Float
  totalCost       Float
  createdAt       DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  sparePart     SparePart     @relation(fields: [sparePartId], references: [id])
}