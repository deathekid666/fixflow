generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String
  password String
  role     String  @default("ENGINEER")
  shopId   String?

  shop           Shop?         @relation(fields: [shopId], references: [id])
  createdOrders  WorkOrder[]   @relation("CreatedBy")
  assignedOrders WorkOrder[]   @relation("AssignedTo")
  logs           OperationLog[]
  notifications  Notification[]
}

model Shop {
  id         String      @id @default(cuid())
  name       String
  users      User[]
  workOrders WorkOrder[]
  spareParts SparePart[]
}

model WorkOrder {
  id          String @id @default(cuid())
  orderNumber String @unique @default(cuid())

  deviceBrand     String
  deviceModel     String
  serialNumber    String?
  imei            String?
  warrantyStart   DateTime?
  warrantyEnd     DateTime?
  isUnderWarranty Boolean @default(false)

  customerName  String
  customerPhone String
  customerEmail String?

  faultDescription String
  appearance       String?
  remarks          String?

  serviceType String @default("IN_STORE")
  repairType  String?
  faultLevel  String @default("LOW")

  status      String @default("RECEIVED")

  receivedAt  DateTime  @default(now())
  doneAt      DateTime?
  deliveredAt DateTime?

  bounceCount Int     @default(0)
  isBounce    Boolean @default(false)

  subtotal         Float  @default(0)
  quotationItems   Float  @default(0)
  discount         Float  @default(0)
  total            Float  @default(0)
  collected        Float  @default(0)
  quotationRemarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopId     String
  userId     String
  assignedTo String?

  shop          Shop                  @relation(fields: [shopId], references: [id])
  creator       User                  @relation("CreatedBy", fields: [userId], references: [id])
  assignee      User?                 @relation("AssignedTo", fields: [assignedTo], references: [id])
  parts         WorkOrderPart[]
  lineItems     QuotationLineItem[]
  logs          OperationLog[]
  attachments   WorkOrderAttachment[]
  bounces       BounceRepair[]
  notifications Notification[]
}

model QuotationLineItem {
  id          String @id @default(cuid())
  label       String
  amount      Float

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  createdAt DateTime @default(now())
}

model BounceRepair {
  id          String @id @default(cuid())
  reason      String
  scenario    String
  createdAt   DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
}

model Notification {
  id        String  @id @default(cuid())
  type      String
  message   String
  read      Boolean @default(false)

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])

  userId    String
  user      User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model SparePart {
  id          String  @id @default(cuid())
  name        String
  partNumber  String?
  description String?
  unitPrice   Float   @default(0)
  stock       Int     @default(0)

  shopId    String
  shop      Shop    @relation(fields: [shopId], references: [id])
  usages    WorkOrderPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkOrderPart {
  id        String @id @default(cuid())
  quantity  Int    @default(1)
  unitPrice Float
  total     Float

  workOrderId String
  sparePartId String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  sparePart SparePart @relation(fields: [sparePartId], references: [id])

  createdAt DateTime @default(now())
}

model OperationLog {
  id          String  @id @default(cuid())
  action      String
  description String?

  createdAt DateTime @default(now())

  workOrderId String
  userId      String

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model WorkOrderAttachment {
  id       String @id @default(cuid())
  filename String
  path     String

  createdAt DateTime @default(now())

  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
}
